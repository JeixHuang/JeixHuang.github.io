{{- $pages := partial "public-posts.html" (where site.RegularPages "Section" "posts") -}}
{{- $pages = $pages.ByDate.Reverse -}}
[
{{- range $i, $p := $pages -}}
  {{- if $i }},{{ end }}
  {{- $excerpt := (or $p.Params.summary $p.Summary) | plainify | htmlUnescape | replaceRE "\\s+" " " | trim " " | truncate 160 -}}
  {
    "title": {{ $p.Title | jsonify }},
    "date": {{ $p.Date.Format "2006-01-02" | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "excerpt": {{ $excerpt | jsonify }},
    "language": {{ $p.Site.Language.Lang | jsonify }},
    "translationKey": {{ $p.Params.translationKey | jsonify }},
    "weekly_report": {{ default false $p.Params.weekly_report | jsonify }}
  }
{{- end -}}
]
